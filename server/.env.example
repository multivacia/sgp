NODE_ENV=development
# Deve coincidir com VITE_DEV_API_PORT na raiz do repo (proxy do Vite → API).
PORT=4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Autenticação (JWT em cookie httpOnly). Mínimo 16 caracteres.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_DAYS=7
AUTH_COOKIE_NAME=sgp_auth

# Lockout por tentativas falhadas de login (conta existente, senha inválida).
# LOGIN_MAX_FAILED_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# Opcional: em produção, permite GET /api/v1/health/db com header X-SGP-Infra-Token (mín. 32 caracteres).
# Se omitido, só sessão humana com permissão system.health_db.
# HEALTH_INFRA_TOKEN=

# Opcional: senha da conta demo criada pelo seed (maria@exemplo.com)
# SEED_DEMO_PASSWORD=SenhaSegura123

# Forma preferida para dev local simples
PGHOST=localhost
PGPORT=5432
PGDATABASE=sgp
PGUSER=postgres
PGPASSWORD=CHANGE_ME

# Opcional: URL completa tem prioridade sobre PG*
# DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/sgp

# Opcional
# PG_POOL_MAX=20
# REQUIRE_DB_ON_STARTUP=1

# ARGOS — ingestão de documento (POST /api/v1/conveyors/document-draft).
# Com ARGOS_INGEST_URL → encaminha ao serviço ARGOS remoto (HTTP).
# Sem URL: pipeline heurístico local (extract → interpret → draft v1), salvo se:
#   ARGOS_USE_MINIMAL_STUB=1 → stub mínimo explícito (ex.: testes), ou
#   ARGOS_REMOTE_REQUIRED=1 → obriga URL remoto (falha no arranque se vazio).
# URL do gateway ARGOS — tipicamente POST .../v1/documents (multipart documentIngestFieldsSchema).
# ARGOS_INGEST_URL=https://argos.example/v1/documents
# ARGOS_INGEST_TOKEN=
# Opcional: callerEnvironment no multipart (até 64 chars).
# ARGOS_CALLER_ENVIRONMENT=development
# Modo de política do pipeline no ARGOS: economy | balanced | quality
# ARGOS_POLICY_MODE=balanced
# ARGOS_INGEST_TIMEOUT_MS=120000
# DOCUMENT_DRAFT_MAX_FILE_BYTES=15728640
# ARGOS_REMOTE_REQUIRED=0
# ARGOS_USE_MINIMAL_STUB=0

# ARGOS — análise de saúde de esteira (cliente SGP; rotas BFF já expostas em /api/v1/conveyors/:id/health-analysis*).
# Base + path; o token reutiliza ARGOS_INGEST_TOKEN (Bearer) se definido.
# ARGOS_BASE_URL=https://argos.example
# ARGOS_CONVEYOR_HEALTH_ANALYZE_PATH=/api/v1/specialists/conveyor-health/analyze
# ARGOS_HEALTH_TIMEOUT_MS=120000
# ARGOS_HEALTH_ENABLED=1

# SUPPORT tickets (MVP)
SUPPORT_TICKETS_ENABLED=0
SUPPORT_EMAIL_ENABLED=0
SUPPORT_WHATSAPP_ENABLED=0
# E-mail (SMTP) — quando SUPPORT_EMAIL_ENABLED=1
# SUPPORT_EMAIL_FROM=sgp@seudominio.com
# SUPPORT_EMAIL_REPLY_TO=suporte@seudominio.com
# SUPPORT_EMAIL_SUBJECT_PREFIX=[SGP]
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=usuario
# SMTP_PASS=senha
# SMTP_REQUIRE_TLS=1
# Listas CSV de destinos por canal
# SUPPORT_ROUTING_DEFAULT_EMAIL=suporte@empresa.com
# SUPPORT_ROUTING_DEFAULT_WHATSAPP=5511999999999
# SUPPORT_ROUTING_MEDIUM_EMAIL=suporte@empresa.com
# SUPPORT_ROUTING_HIGH_EMAIL=suporte@empresa.com,gestao@empresa.com
# SUPPORT_ROUTING_HIGH_WHATSAPP=5511999999999,5511888888888